  "description": "A lightweight, high-performance React grid component built with CSS Grid and TypeScript.",
  "author": "Tony Tom K",
  "license": "MIT",
  "keywords": [
    "react",
    "grid",
    "table",
    "typescript",
    "vite",
    "flexbox"
  ],
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tonytomk/free-grid-react.git"
  },
  "bugs": {
    "url": "https://github.com/tonytomk/free-grid-react/issues"
  },
  "homepage": "https://github.com/tonytomk/free-grid-react#readme",
  "exports": {
    ".": {
      "import": "./dist/free-grid.js",
      "require": "./dist/free-grid.umd.cjs"
    },
    "./src/Grid.css": "./src/Grid.css",
    "./free-grid.css": "./dist/free-grid.css",
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
